@page "/detalle-votacion"
@using Shared.DTO
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Configuration
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@inject Web.Services.SimpleAuthService AuthService
@inject IJSRuntime JSRuntime

<div class="header-back-link" >
    @if(FromDashboard) 
    {
        <a href="#" class="header-back" @onclick:preventDefault @onclick='() => NavigationManager.NavigateTo($"/mis-votaciones")'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>
            Volver al Dashboard
        </a>
    } 
    else 
    {
        <a href="#" class="header-back" @onclick:preventDefault @onclick='() => NavigationManager.NavigateTo($"/detalle-evento?id={EventoId}")'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>
            Volver al evento
        </a>
    }
</div>

<main >
    @if (showToast)
    {
        <div class="toast-success">
            ✅ ¡Los jurados han sido guardados exitosamente!
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="delete-alert">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            @errorMessage
        </div>
    }

    @if (votacionDetalle == null)
    {
        <p class="empty-state">Cargando detalles de la votación...</p>
    }
    else
    {
        <!-- DEBUG INFO: esInvitado=@esInvitado, yaVotoUsuario=@yaVotoUsuario, VotoEmitido=@VotoEmitido, guestCode=@guestCode, CodigoAcceso=@votacionDetalle.CodigoAcceso, EstaActiva=@votacionDetalle.EstaActiva, Estado=@votacionDetalle.Estado -->
        @if ((esJurado && !esAdmin && !yaVotoUsuario && votacionDetalle.EstaActiva && votacionDetalle.Estado == "Activa" && votacionDetalle.Jurados.Any(j => j.Id == currentUserId)) ||
             (esInvitado && !yaVotoUsuario && votacionDetalle.EstaActiva && string.Equals(votacionDetalle.CodigoAcceso, guestCode, StringComparison.OrdinalIgnoreCase)))
        {
            <div class="vote-trigger-container">
                <button class="btn-primary btn-emitir" @onclick='() => NavigationManager.NavigateTo($"/emitir-voto?eventoId={EventoId}&votacionId={VotacionId}")'>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    ¡Emitir mi Voto!
                </button>
            </div>
        }

        <div class="header-top">
            <div class="header-info" style="padding-right: 1rem;">
                <h1 class="page-title" style="margin-bottom: 0.5rem; margin-top: 0">@votacionDetalle.Nombre</h1>
                <h2 class="page-subtitle">@(votacionDetalle.Descripcion ?? "Detalles de la votación")</h2>
                @if (votacionDetalle.Premio != null)
                {
                    <div style="margin-top:.5rem; display:flex; gap:.6rem; align-items:center;">
                        <div style="font-size:1.4rem;">@votacionDetalle.Premio.Emoji</div>
                        <div>
                            <div style="font-weight:600;">@votacionDetalle.Premio.Nombre</div>
                            @if (!string.IsNullOrEmpty(votacionDetalle.Premio.ProyectoGanadorNombre))
                            {
                                <div style="font-size:.85rem; color:var(--muted);">Ganador: @votacionDetalle.Premio.ProyectoGanadorNombre</div>
                            }
                        </div>
                    </div>
                }
                <div class="meta-info">
                    <span>Categoría: @(string.IsNullOrEmpty(votacionDetalle.Categoria) ? "Estándar" : votacionDetalle.Categoria)</span>
                    <span>Reglas: General</span>
                    @if (esAdmin && !string.IsNullOrEmpty(votacionDetalle.CodigoAcceso))
                    {
                        <span style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(255,255,255,0.05); padding:0.2rem 0.5rem; border-radius:4px; border:1px dashed var(--border);">
                            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                            Código Invitados: <strong style="color:var(--accent); letter-spacing:1px; font-family:monospace; font-size:1.1rem;">@votacionDetalle.CodigoAcceso</strong>
                        </span>
                    }
                </div>
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 1rem; align-items: flex-end;">
                @if (esAdmin)
                {
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="btn-ghost" style="padding: 0.4rem 1rem; border: 1px solid rgba(79,124,255,0.3); background: rgba(79,124,255,0.15); color: var(--accent); border-radius: 8px; display: flex; align-items: center; gap: 0.5rem; transition: background .15s, border-color .15s, transform .15s; cursor:pointer;" @onclick="EditarVotacion" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                            ✏️ Editar
                        </button>
                        <button class="btn-ghost" style="padding: 0.4rem 1rem; border: 1px solid rgba(255,79,110,0.3); background: rgba(255,79,110,0.12); color: var(--danger); border-radius: 8px; display: flex; align-items: center; gap: 0.5rem; transition: background .15s, border-color .15s, transform .15s; cursor:pointer;" @onclick="PrepararEliminarVotacion" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                            🗑️ Eliminar
                        </button>
                    </div>
                }

                <div class="live-card card" style="margin: 0; min-width: 320px;">
                    <div class="status" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <span>@votacionDetalle.Estado</span>
                        @if (esAdmin)
                        {
                            <button class="btn-cancel" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); font-size: 0.75rem; padding: 0.2rem 0.5rem; color: white;" @onclick='() => NavigationManager.NavigateTo($"/gestion-estado?eventoId={EventoId}&votacionId={VotacionId}")'>⚙️ Gestión Estado</button>
                        }
                    </div>
                <div class="label">TIEMPO RESTANTE</div>
                <div class="time">@tiempoRestante</div>
                <div class="close-text">Cierre: @votacionDetalle.FechaFin.ToString("dd/MM/yyyy HH:mm") (Hora Local)</div>
                
                @if (esAdmin && votacionDetalle.EstaActiva)
                {
                    <div class="live-actions">
                        <button class="btn-state-extend" style="padding: 0.5rem 1rem; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-family: 'Syne', sans-serif;" @onclick='() => AccionVotacion("extender")'>Extender</button>
                        <button class="btn-state-close" style="padding: 0.5rem 1rem; border: none; border-radius: 8px; color: white; font-weight: 600; cursor: pointer; font-family: 'Syne', sans-serif;" @onclick='() => AccionVotacion("cerrar")'>Cerrar ya</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="stats-grid">
            <div class="stat-card-custom">
                <p class="stat-title">Jurados Participantes</p>
                <h3 class="stat-value">@votacionDetalle.VotantesUnicos <span class="stat-value-fraction">/ @votacionDetalle.TotalJurados</span></h3>
                <div class="stat-desc">han emitido sus valoraciones</div>
            </div>
            <div class="stat-card-custom">
                <p class="stat-title">Participación</p>
                <h3 class="stat-value" style="color: var(--success);"><span>@votacionDetalle.ParticipacionPorcentaje</span>%</h3>
                <div class="stat-desc">@(votacionDetalle.TotalJurados - votacionDetalle.VotantesUnicos) jurado(s) pendiente(s)</div>
            </div>
            <div class="stat-card-custom yellow-border">
                <p class="stat-title">Proyectos en Carrera</p>
                <h3 class="stat-value" style="color: #facc15;">@votacionDetalle.ProyectosEnCarrera</h3>
                <div class="stat-desc">con al menos 1 voto</div>
            </div>
            <div class="stat-card-custom purple-border">
                <p class="stat-title">Líder Provisional</p>
                <h3 class="stat-value" style="color: var(--accent2); font-size: 1.5rem;">@(string.IsNullOrEmpty(votacionDetalle.LiderProvisional) ? "N/A" : votacionDetalle.LiderProvisional)</h3>
                <div class="stat-desc">@(string.IsNullOrEmpty(votacionDetalle.LiderProvisional) ? "Ningún voto aún" : $"{votacionDetalle.LiderVotos} pts — {votacionDetalle.LiderPorcentaje}% del Share")</div>
            </div>
        </div>

        <div class="content-grid">
            <div class="section-panel">
                <div class="panel-header">
                    <div class="panel-title">
                        <span>🏆</span> @(votacionDetalle.EstaActiva ? "Resultados provisionales" : "Resultados Finales")
                    </div>
                    @if (votacionDetalle.EstaActiva)
                    {
                        <div class="panel-badge real-time">⚡ TIEMPO REAL</div>
                    }
                    else
                    {
                        <div class="panel-badge success" style="background: rgba(34,201,132,.15); color: #22c984;">✅ FINALIZADO</div>
                    }
                </div>
                <div class="list-wrapper">
                    @if (votacionDetalle.ResultadosProvisionales == null || !votacionDetalle.ResultadosProvisionales.Any())
                    {
                        <div class="empty-state">
                            <p>No hay resultados disponibles en esta votación todavía.</p>
                        </div>
                    }
                    else
                    {
                        var maxVal = votacionDetalle.TotalJurados > 0 ? votacionDetalle.TotalJurados * 5.0 : 5.0;

                        @if (!votacionDetalle.EstaActiva && votacionDetalle.ResultadosProvisionales.Any())
                        {
                            <div class="podium-container" style="display: flex; justify-content: center; gap: .75rem; align-items: flex-end; margin-bottom: 2.5rem; margin-top: 1rem; flex-shrink: 0;">
                                @{
                                    var top3 = votacionDetalle.ResultadosProvisionales.Take(3).ToList();
                                    if (top3.Count > 1) {
                                        <div class="podium-item second" style="text-align: center; width: 30%; max-width: 110px;">
                                            <div style="font-size: 2.2rem; margin-bottom: -8px;">🥈</div>
                                            <div style="background: linear-gradient(180deg, #e2e8f0 0%, #94a3b8 100%); height: 90px; border-radius: 8px 8px 0 0; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: .5rem; color: #0f172a; font-weight: 800;">
                                            <div style="font-size: .75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 .4rem;">@top3[1].Nombre</div>
                                            <div>@top3[1].SumaValoracion★</div>
                                        </div>
                                        </div>
                                    }
                                    if (top3.Count > 0) {
                                        <div class="podium-item first" style="text-align: center; width: 33%; max-width: 130px;">
                                            <div style="font-size: 2.8rem; margin-bottom: -10px, z-index: 10, position: relative;">🥇</div>
                                            <div style="background: linear-gradient(180deg, #fef08a 0%, #eab308 100%); height: 120px; border-radius: 8px 8px 0 0; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: .5rem; color: #422006; font-weight: 800; box-shadow: 0 -5px 20px rgba(234,179,8,0.3);">
                                            <div style="font-size: .85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 .4rem;">@top3[0].Nombre</div>
                                            <div>@top3[0].SumaValoracion★</div>
                                        </div>
                                        </div>
                                    }
                                    if (top3.Count > 2) {
                                        <div class="podium-item third" style="text-align: center; width: 30%; max-width: 100px;">
                                            <div style="font-size: 2rem; margin-bottom: -8px;">🥉</div>
                                            <div style="background: linear-gradient(180deg, #fed7aa 0%, #d97706 100%); height: 70px; border-radius: 8px 8px 0 0; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: .5rem; color: #451a03; font-weight: 800;">
                                            <div style="font-size: .75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 .4rem;">@top3[2].Nombre</div>
                                            <div>@top3[2].SumaValoracion★</div>
                                        </div>
                                        </div>
                                    }
                                }
                            </div>
                        }

                        for (int i = 0; i < votacionDetalle.ResultadosProvisionales.Count; i++)
                        {
                            var r = votacionDetalle.ResultadosProvisionales[i];
                            var perc = (r.SumaValoracion / maxVal) * 100;
                            var posColor = i == 0 ? "#facc15" : (i == 1 ? "var(--accent2)" : "inherit");
                            var barColor = i == 0 ? "#facc15" : (i == 1 ? "var(--accent2)" : "var(--accent)");
                            
                            <div class="res-item">
                                <div class="res-pos" style="color: @posColor;">#@(i+1)</div>
                                <div class="res-info">
                                    <h4 class="res-title">@r.Nombre</h4>
                                    <p class="res-desc">@(string.IsNullOrEmpty(r.DescripcionCorta) ? "Sin descripción" : r.DescripcionCorta)</p>
                                </div>
                                <div class="res-votes">
                                    <strong class="res-votes-val">@r.SumaValoracion pts</strong>
                                    <span class="res-votes-count">@r.VotosCount votos</span>
                                </div>
                                <div class="res-bar-container">
                                    <div class="res-bar-fill" style="background: @barColor; width: @(perc.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="section-panel">
                <div class="panel-header" style="justify-content: space-between; align-items: center; display: flex; flex-wrap: wrap; gap: 1rem;">
                    <div class="panel-title" style="display: flex; align-items: center; gap: 0.5rem;">
                        <span>💬</span> Comentarios Anónimos
                        <div class="panel-badge">@ComentariosMostrados.Count() total</div>
                    </div>
                    <div style="display: flex; gap: 1rem; align-items: center; margin-left: auto;">
                        @if (votacionDetalle.Comentarios != null && votacionDetalle.Comentarios.Any())
                        {
                            <select @bind="selectedComentarioProyectoId" style="padding: 0.3rem 0.5rem; border-radius: 4px; border: 1px solid var(--border); font-size: 0.85rem; background-color: #1e1e24; color: #ffffff; outline: none;">
                                <option value="0" style="background-color: #1e1e24; color: #ffffff;">Todos los proyectos</option>
                                @foreach (var p in votacionDetalle.Comentarios.Where(c => c.ProyectoId > 0).GroupBy(c => c.ProyectoId).Select(g => new { Id = g.Key, Nombre = g.First().ProyectoNombre }))
                                {
                                    <option value="@p.Id" style="background-color: #1e1e24; color: #ffffff;">@p.Nombre</option>
                                }
                            </select>
                        }

                        @if ((votacionDetalle.Estado == "Cerrada" || votacionDetalle.Estado == "Finalizada") && votacionDetalle.Comentarios?.Count >= 2 && votacionDetalle.ResultadosProvisionales?.Any() == true)
                        {
                            <div style="position: relative;">
                                <button class="btn-primary" style="background-color: #333; color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem;" @onclick="ToggleResumenMenu">
                                    RESUMEN IA
                                </button>
                                @if (showResumenMenu)
                                {
                                    <div style="position: absolute; right: 0; top: 100%; margin-top: 0.5rem; background: white; border: 1px solid #ddd; border-radius: 4px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); z-index: 10; min-width: 250px; padding: 0.5rem;">
                                        <p style="margin: 0 0 0.5rem 0; font-size: 0.85rem; font-weight: bold; color: #000000;">Elegir Proyecto:</p>
                                        <select @bind="selectedProyectoResumenId" style="width: 100%; padding: 0.25rem; font-size: 0.85rem; margin-bottom: 0.5rem; background-color: #ffffff; color: #000000; border: 1px solid #ccc;">
                                            <option value="0" style="background-color: #ffffff; color: #000000;">-- Seleccione --</option>
                                            @foreach(var p in votacionDetalle.ResultadosProvisionales)
                                            {
                                                <option value="@p.Id" style="background-color: #ffffff; color: #000000;">@p.Nombre</option>
                                            }
                                        </select>
                                        <button class="btn-primary" style="width: 100%; padding: 0.25rem; font-size: 0.85rem;" @onclick="GetResumenIAProyecto" disabled="@(selectedProyectoResumenId == 0 || isResumenLoading)">
                                            @(isResumenLoading ? "Cargando..." : "Sintetizar")
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(resumenIAText))
                {
                    <div style="margin: 1rem; padding: 1rem; border: 1px solid #ccc; border-radius: 4px; background: #fafafa;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <strong style="font-size: 0.85rem; color: #555;">✨ RESUMEN IA</strong>
                            @if (!string.IsNullOrEmpty(selectedProyectoResumenNombre))
                            {
                                <span style="font-size: 0.85rem; color: #777; font-weight: bold; padding: 0.1rem 0.5rem; background: #eee; border-radius: 12px;">@selectedProyectoResumenNombre</span>
                            }
                        </div>
                        @if (resumenIAText.StartsWith("El resumen") || resumenIAText.StartsWith("No hay") || resumenIAText.StartsWith("Error") || resumenIAText.StartsWith("No se ha"))
                        {
                            <p style="margin: 0; font-size: 0.95rem; color: #d32f2f;">@resumenIAText</p>
                        }
                        else
                        {
                            <p style="margin: 0; font-size: 0.95rem; color: #333;">Los usuarios opinan que: @resumenIAText</p>
                        }
                    </div>
                }

                <div class="list-wrapper">
                    @if (votacionDetalle.Comentarios == null || !votacionDetalle.Comentarios.Any())
                    {
                        <div class="empty-state">
                            <p>Nadie ha comentado aún. ¡Sé el primero!</p>
                        </div>
                    }
                    else if (!ComentariosMostrados.Any())
                    {
                        <div class="empty-state">
                            <p>No hay comentarios para este proyecto aún.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var c in ComentariosMostrados)
                        {
                            var initial = string.IsNullOrEmpty(c.Autor) ? "AN" : (c.Autor.Length > 2 ? c.Autor.Substring(0, 2).ToUpper() : c.Autor.ToUpper());
                            <div class="comment-item">
                                <div class="comment-top">
                                    <div class="comment-user-box">
                                        <div class="comment-avatar">@initial</div> 
                                        @(string.IsNullOrEmpty(c.Autor) ? "Anónimo" : c.Autor)
                                    </div>
                                    <div class="comment-time">@c.Fecha.ToString("HH:mm")</div>
                                </div>
                                @if (!string.IsNullOrEmpty(c.Etiqueta))
                                {
                                    <div class="comment-tag">🏷️ @c.Etiqueta</div>
                                }
                                <div class="comment-text">@c.Contenido</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @if (esAdmin)
        {
            <div class="section-panel jurados-panel">
                <div class="panel-header">
                    <div class="panel-title">⚖️ Asignar Jurados</div>
                    <div class="panel-badge">Admin</div>
                </div>
                <div class="jurados-toolbar">
                    <input type="text" class="jurados-input" @bind="busquedaJurado" @bind:event="oninput" placeholder="Buscar jurados por nombre o por DNI..." style="width: 100%; max-width: 400px; padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border);" />
                    <button class="btn-save" @onclick="GuardarJuradosFinal">Guardar Jurados</button>
                </div>

                <div class="jurados-grid" style="margin-top: 1rem; max-height: 300px; overflow-y: auto; border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
                    @if (todosLosJurados == null)
                    {
                        <div class="empty-state"><p>Cargando jurados...</p></div>
                    }
                    else if (!todosLosJurados.Any())
                    {
                        <div class="empty-state"><p>No hay jurados registrados en el sistema.</p></div>
                    }
                    else
                    {
                        var filtrados = todosLosJurados
                            .Where(j => string.IsNullOrWhiteSpace(busquedaJurado) || 
                                        j.Nombre.Contains(busquedaJurado, StringComparison.OrdinalIgnoreCase) || 
                                        (j.Dni != null && j.Dni.Contains(busquedaJurado, StringComparison.OrdinalIgnoreCase)))
                            .ToList();

                        if (!filtrados.Any())
                        {
                            <div class="empty-state"><p>No se encontraron coincidiencias.</p></div>
                        }
                        else
                        {
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                                @foreach (var j in filtrados)
                                {
                                    <label class="jurado-item" style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem; background: var(--bg-hover); border-radius: 4px; cursor: pointer;">
                                        <input type="checkbox" checked="@juradosSeleccionadosIds.Contains(j.Id)" @onchange="@(e => ToggleJuradoSeleccion(j.Id, (bool)(e.Value ?? false)))" />
                                        <div style="display: flex; flex-direction: column;">
                                            <strong style="font-size: 0.9rem;">@j.Nombre</strong>
                                            <small style="color: var(--muted); font-size: 0.75rem;">@j.Dni</small>
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
</main>

@if (votacionAEliminar != null)
{
    <div class="modal-overlay open" style="display:flex;">
        <div class="modal-box">
            <div class="modal-title">Eliminar votación</div>
            <p class="modal-body">Esta acción es irreversible. Se eliminará la votación y sus resultados.</p>
            <div class="modal-event-name">@votacionAEliminar.Nombre</div>

            @if (!string.IsNullOrEmpty(errorBorrarVotacion))
            {
                <div class="modal-error visible">@errorBorrarVotacion</div>
            }

            <div class="modal-actions">
                <button class="btn-ghost" @onclick="CancelarEliminarVotacion">Cancelar</button>
                <button class="btn-danger" @onclick="ConfirmarEliminarVotacion" disabled="@isDeletingVotacion">
                    @(isDeletingVotacion ? "Eliminando..." : "Sí, eliminar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int EventoId { get; set; }
    
    [SupplyParameterFromQuery]
    public int VotacionId { get; set; }

    [SupplyParameterFromQuery]
    public bool FromDashboard { get; set; } 

    [SupplyParameterFromQuery(Name = "votoEmitido")]
    public bool VotoEmitido { get; set; }

    // Variables de eliminacion
    private DetalleVotacionDto? votacionAEliminar = null;
    private bool isDeletingVotacion = false;
    private string errorBorrarVotacion = "";

    // Utiliza un DTO de respuesta que coincida con lo que tu endpoint devuelve.
    // He utilizado un tipo 'dynamic' o puedes crear el 'VotacionDetalleDTO' in tu proyecto Shared.
    private DetalleVotacionDto? votacionDetalle;
    private string errorMessage = "";
    
    // Temporizador
    private System.Timers.Timer? timer;
    private string tiempoRestante = "--:--:--";
    
    // Roles de usuario autenticado
    private bool esAdmin = false;
    private bool esJurado = false; 
    private bool esInvitado = false;
    private bool yaVotoUsuario = false;
    private string guestCode = "";
    private int currentUserId = 0;
    private bool showToast = false;

    // Resumen IA
    private bool showResumenMenu = false;
    private int selectedProyectoResumenId = 0;
    private string selectedProyectoResumenNombre = "";
    private bool isResumenLoading = false;
    private string resumenIAText = "";

    // Patrón Observador (Conexión WebSocket)
    private HubConnection? hubConnection;

    private int selectedComentarioProyectoId = 0;

    private IEnumerable<ComentarioAnonimoDto> ComentariosMostrados =>
        selectedComentarioProyectoId == 0 
            ? (votacionDetalle?.Comentarios ?? Enumerable.Empty<ComentarioAnonimoDto>())
            : (votacionDetalle?.Comentarios?.Where(c => c.ProyectoId == selectedComentarioProyectoId) ?? Enumerable.Empty<ComentarioAnonimoDto>());

    private void ToggleResumenMenu()
    {
        showResumenMenu = !showResumenMenu;
    }

    private async Task GetResumenIAProyecto()
    {
        if (selectedProyectoResumenId == 0) return;
        
        isResumenLoading = true;
        resumenIAText = "";
        selectedProyectoResumenNombre = votacionDetalle?.ResultadosProvisionales?.FirstOrDefault(p => p.Id == selectedProyectoResumenId)?.Nombre ?? "";
        StateHasChanged();
        
        try
        {
            var res = await Http.GetFromJsonAsync<System.Text.Json.JsonElement>($"api/Votacion/{EventoId}/{VotacionId}/proyecto/{selectedProyectoResumenId}/resumen");
            if (res.TryGetProperty("resumen", out var resValue))
            {
                resumenIAText = resValue.GetString() ?? "No disponible.";
                showResumenMenu = false;
            }
        }
        catch (Exception ex)
        {
            resumenIAText = $"Error: {ex.Message}";
        }
        finally
        {
            isResumenLoading = false;
            StateHasChanged();
        }
    }

    // Búsqueda de Jurados
    private string busquedaJurado = "";
    private List<UsuarioBuscadorDto>? todosLosJurados = null;
    private HashSet<int> juradosSeleccionadosIds = new();

    protected override async Task OnInitializedAsync()
    {
        if (EventoId <= 0 || VotacionId <= 0)
        {
            NavigationManager.NavigateTo("/listado-eventos");
            return;
        }
        
        await CheckAuthentication();

        if (VotoEmitido)
        {
            yaVotoUsuario = true;
        }

        await CargarDetalleVotacion();

        // Patrón Observador: Iniciar conexión de red y suscribirse
        var baseApiUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:7185/";
        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{baseApiUrl}votacionhub")
            .Build();

        hubConnection.On("ActualizarDatosVotacion", async () =>
        {
            // El observador recibe la notificación y pide el estado actualizado (Pull)
            await InvokeAsync(async () =>
            {
                await CargarDetalleVotacion();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
        
        // Attach
        await hubConnection.SendAsync("SuscribirObservador", VotacionId);
    }

    private async Task CheckAuthentication()
    {
        try
        {
            var userJson = await AuthService.GetUsuarioActivoAsync();
            if (!string.IsNullOrEmpty(userJson))
            {
                using var doc = System.Text.Json.JsonDocument.Parse(userJson);
                
                if (doc.RootElement.TryGetProperty("id", out var idProp) || doc.RootElement.TryGetProperty("Id", out idProp))
                {
                    currentUserId = idProp.GetInt32();
                }

                if (doc.RootElement.TryGetProperty("rol", out var rolProp) || doc.RootElement.TryGetProperty("Rol", out rolProp))
                {
                    var rol = rolProp.GetString();
                    esJurado = rol == "Jurado";
                    esAdmin = rol == "Admin" || rol == "Administrador" || rol == "Creador";
                    esInvitado = rol == "Invitado";
                }
                
                if (esInvitado)
                {
                    if (doc.RootElement.TryGetProperty("guestCode", out var codeProp) || doc.RootElement.TryGetProperty("GuestCode", out codeProp))
                    {
                        guestCode = codeProp.GetString() ?? "";
                    }
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error parsing user authentication in CheckAuthentication: {ex.Message}"); }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // No se usa localStorage; la verificación se hace contra el API en CargarDetalleVotacion
        return base.OnAfterRenderAsync(firstRender);
    }

    private async Task CargarDetalleVotacion()
    {
        errorMessage = "";
        try
        {
            votacionDetalle = await Http.GetFromJsonAsync<DetalleVotacionDto>($"api/Votacion/{EventoId}/{VotacionId}/detalle");

            // Verificar contra el API si el usuario ya votó (fuente de verdad fiable)
            if (!yaVotoUsuario && currentUserId > 0)
            {
                try
                {
                    var res = await Http.GetFromJsonAsync<System.Text.Json.JsonElement>(
                        $"api/Votacion/{EventoId}/{VotacionId}/ya-vote?userId={currentUserId}");
                    if (res.TryGetProperty("yaVoto", out var prop) && prop.GetBoolean())
                        yaVotoUsuario = true;
                }
                catch { }
            }
            
            if (votacionDetalle != null)
            {
                if (esInvitado && !string.Equals(votacionDetalle.CodigoAcceso, guestCode, StringComparison.OrdinalIgnoreCase))
                {
                    NavigationManager.NavigateTo($"/detalle-evento?Id={EventoId}");
                    return;
                }

                SetupTimer();
                if (votacionDetalle.Jurados != null)
                {
                    juradosSeleccionadosIds.Clear();
                    foreach(var j in votacionDetalle.Jurados)
                    {
                        juradosSeleccionadosIds.Add(j.Id);
                    }
                }
            }

            if (esAdmin)
            {
                await CargarTodosLosJurados();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar la votación: {ex.Message}";
        }
    }

    private async Task CargarTodosLosJurados()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<List<UsuarioBuscadorDto>>("api/Usuario/jurados");
            todosLosJurados = res ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar lista de jurados: {ex.Message}";
            todosLosJurados = new();
        }
    }

    private void ToggleJuradoSeleccion(int id, bool estáSeleccionado)
    {
        if (estáSeleccionado)
            juradosSeleccionadosIds.Add(id);
        else
            juradosSeleccionadosIds.Remove(id);
    }

    private void QuitarJurado(int id)
    {
        juradosSeleccionadosIds.Remove(id);
    }

    private async Task GuardarJuradosFinal()
    {
        try
        {
            var payload = new AsignarJuradosDto
            {
                AdministradorId = currentUserId > 0 ? currentUserId : 1, // Usa el id real si lo hay
                VotacionId = VotacionId,
                JuradoIds = juradosSeleccionadosIds.ToList()
            };

            var res = await Http.PostAsJsonAsync($"api/Votacion/{VotacionId}/asignar-jurados", payload);
            if (res.IsSuccessStatusCode)
            {
                errorMessage = ""; 
                showToast = true;
                StateHasChanged();
                await Task.Delay(3000);
                showToast = false;
                StateHasChanged();
            }
            else
            {
                errorMessage = "No se pudo procesar la asignación de jurados.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al asignar jurados: {ex.Message}";
        }
    }

    private async Task AccionVotacion(string accion)
    {
        try
        {
            var res = await Http.PostAsync($"api/Votacion/{EventoId}/{VotacionId}/accion?accion={accion}", null);
            if (res.IsSuccessStatusCode)
            {
                await CargarDetalleVotacion();
            }
            else
            {
                var dict = await res.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                errorMessage = dict?["error"]?.ToString() ?? "Error al procesar la acción.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private void SetupTimer()
    {
        timer?.Dispose();
        timer = new System.Timers.Timer(1000);
        timer.Elapsed += (s, e) => UpdateTime();
        timer.Start();
        UpdateTime();
    }

    private void UpdateTime()
    {
        if (votacionDetalle == null) return;
        
        var now = DateTime.UtcNow;
        if (votacionDetalle.Estado == "Pendiente de iniciar" || now < votacionDetalle.FechaInicio)
        {
            tiempoRestante = "Pendiente de inicio";
        }
        else if (votacionDetalle.Estado == "Cerrada" || now >= votacionDetalle.FechaFin)
        {
            tiempoRestante = "00:00:00";
            timer?.Stop();
            
            if (votacionDetalle.EstaActiva)
            {
                InvokeAsync(async () => {
                    await CargarDetalleVotacion();
                    StateHasChanged();
                });
                return;
            }
        }
        else
        {
            var diff = votacionDetalle.FechaFin - now;
            tiempoRestante = diff.TotalSeconds > 0 ? $"{(int)diff.TotalHours:D2}:{diff.Minutes:D2}:{diff.Seconds:D2}" : "00:00:00";
        }
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        timer?.Dispose();
        if (hubConnection is not null)
        {
            // Dettach (Patrón Observador)
            _ = hubConnection.SendAsync("CancelarSuscripcion", VotacionId);
            _ = hubConnection.DisposeAsync();
        }
    }

    private void EditarVotacion()
    {
        NavigationManager.NavigateTo($"/editar-votacion/{EventoId}/{VotacionId}?fromDetail=true");
    }

    private void PrepararEliminarVotacion()
    {
        votacionAEliminar = votacionDetalle;
        errorBorrarVotacion = "";
    }

    private void CancelarEliminarVotacion()
    {
        votacionAEliminar = null;
    }

    private async Task ConfirmarEliminarVotacion()
    {
        if (votacionAEliminar == null) return;
        
        isDeletingVotacion = true;
        errorBorrarVotacion = "";

        try
        {
            var res = await Http.DeleteAsync($"api/Votacion/{EventoId}/{votacionAEliminar.Id}");
            if (res.IsSuccessStatusCode)
            {
                votacionAEliminar = null;
                NavigationManager.NavigateTo($"/detalle-evento?id={EventoId}");
            }
            else
            {
                errorBorrarVotacion = "No se pudo eliminar la votación.";
            }
        }
        catch (Exception ex)
        {
            errorBorrarVotacion = $"Error al eliminar votación: {ex.Message}";
        }
        finally
        {
            isDeletingVotacion = false;
        }
    }
}
