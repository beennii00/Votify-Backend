@page "/register"
@layout Web.Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using Shared.DTO


<div class="auth-container">
    <div class="auth-logo">Votify</div>
    <p class="auth-subtitle">Crea tu cuenta plataforma</p>
    
    <EditForm EditContext="editContext" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        
        <div class="form-group">
            <label for="nombre">Nombre Completo</label>
            <InputText id="nombre" class="form-control" placeholder="Ej: Marcos M" @bind-Value="registerModel.Nombre" />
            <ValidationMessage For="@(() => registerModel.Nombre)" />
        </div>

        <div class="form-group">
            <label for="dni">Documento de Identidad</label>
            <div style="display: flex; gap: 0.5rem;">
                <InputSelect @bind-Value="registerModel.TipoDocumento" @bind-Value:after="() => editContext?.NotifyFieldChanged(new FieldIdentifier(registerModel, nameof(registerModel.Dni)))" class="form-control" style="width: 115px; flex-shrink: 0; padding: 0.8rem 0.5rem; text-align: center;">
                    <option value="DNI">DNI</option>
                    <option value="NIE">NIE</option>
                    <option value="Pasaporte">Pasap.</option>
                </InputSelect>
                <InputText id="dni" class="form-control" placeholder="Ej: 12345678A" @bind-Value="registerModel.Dni" />
            </div>
            <ValidationMessage For="@(() => registerModel.Dni)" />
        </div>
        
        <div class="form-group">
            <label for="password">Contraseña</label>
            <InputText type="password" id="password" class="form-control" placeholder="Mínimo 6 carácteres" 
                       @bind-Value="registerModel.Contrasenya" />
            <ValidationMessage For="@(() => registerModel.Contrasenya)" />
        </div>

        <div class="form-group">
            <label for="confirmarPassword">Confirmar contraseña</label>
            <InputText type="password" id="confirmarPassword" class="form-control" placeholder="Repite la contraseña" 
                       @bind-Value="registerModel.ConfirmarPassword" />
            <ValidationMessage For="@(() => registerModel.ConfirmarPassword)" />
        </div>

        <div class="form-group">
            <label for="rol">Perfil (Rol)</label>
            <InputSelect id="rol" class="form-control" @bind-Value="registerModel.Rol">
                <option value="Concursante">Concursante</option>
                <option value="Jurado">Jurado</option>
                <option value="Administrador">Administrador</option>
                <option value="Supervisor">Supervisor</option>
            </InputSelect>
            <ValidationMessage For="@(() => registerModel.Rol)" />

        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="margin-bottom: 1rem;">
                <Web.Components.ErrorAlert Message="@errorMessage" Type="error" />
            </div>
        }
        <button type="submit" class="btn-primary full-width" disabled="@(isLoading || (editContext != null && editContext.GetValidationMessages().Any()))">
            @(isLoading ? "Creando..." : "Crear cuenta")
        </button>
    </EditForm>
    
    <div class="auth-footer">
        ¿Ya tienes una cuenta? <a href="/login">Inicia sesión</a>
    </div>
</div>

@if (showToast)
{
    <div class="toast show @(isSuccessToast ? "success" : "error")" id="toast">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            @if (isSuccessToast)
            {
                <polyline points="20 6 9 17 4 12" />
            }
            else
            {
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            }
        </svg>
        <span>@toastMessage</span>
    </div>
}

@code {
private RegisterUsuarioDTO registerModel = new() { Rol = "Concursante" };
private EditContext? editContext;
private string errorMessage = "";
private bool isLoading;
    
private bool showToast;
private bool isSuccessToast;
private string toastMessage = "";

protected override void OnInitialized()
{
    editContext = new EditContext(registerModel);
    editContext.OnValidationStateChanged += (sender, eventArgs) => StateHasChanged();
    editContext.OnFieldChanged += (sender, eventArgs) => StateHasChanged();
}

    

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = "";
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/usuario/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                ShowToast("Usuario creado correctamente, redirigiendo...", true);
                
                await Task.Delay(2000);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                try
                {
                    var errorObj = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(text);
                    if (errorObj.TryGetProperty("message", out var msgElement))
                    {
                        errorMessage = msgElement.GetString() ?? "Error desconocido";
                    }
                    else
                    {
                        errorMessage = "Error en el registro.";
                    }
                }
                catch
                {
                    errorMessage = "Error en el registro.";
                }
                
                ShowToast("No se pudo crear la cuenta", false);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error de conexión con el servidor.";
            ShowToast("Error de conexión", false);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowToast(string message, bool success)
    {
        toastMessage = message;
        isSuccessToast = success;
        showToast = true;
        StateHasChanged();
        
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            showToast = false;
            await InvokeAsync(StateHasChanged);
        });
    }
}
