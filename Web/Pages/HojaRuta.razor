@page "/hoja-ruta"
@using Shared.DTO
@using Markdig
@using System.Text.Json
@inject HttpClient Http
@inject Web.Services.SimpleAuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<!-- Breadcrumb -->
<div class="breadcrumb" style="display:flex; align-items:center; gap:.5rem; font-size:.8rem; color:var(--muted); margin-bottom:2rem;">
    <a href="/dashboard-concursante" style="color:var(--muted); text-decoration:none;">Dashboard</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:12px; height:12px; opacity:.5;">
        <polyline points="9 18 15 12 9 6"/>
    </svg>
    <span style="color:var(--text);">Hoja de Ruta</span>
</div>

<div class="page-header" style="display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem;">
    <h1 class="page-title" style="margin-bottom: 0; display:flex; align-items:center; gap:0.5rem;">
        <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        Hoja de Ruta <span>Personalizada</span>
    </h1>
    <p class="page-subtitle" style="margin-top: 0;">Plan de acci�n generado por IA basado en el feedback de los jurados.</p>
</div>

<div class="form-card" style="padding: 3rem; min-height: 400px; display: flex; flex-direction: column; align-items: @(!HasGeneratedResult && !IsLoading ? "center" : "stretch"); justify-content: @(!HasGeneratedResult && !IsLoading ? "center" : "flex-start"); text-align: @(!HasGeneratedResult && !IsLoading ? "center" : "left");">
    
    @if (ShowError)
    {
        <div style="display:flex; flex-direction:column; align-items:center; text-align:center; padding: 2rem;">
            <svg viewBox="0 0 24 24" width="60" height="60" stroke="#d32f2f" stroke-width="2" fill="none" style="margin-bottom:1rem;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <h2 style="margin-bottom: 1rem;">Error al generar la hoja de ruta</h2>
            <p style="color:var(--muted); max-width: 500px; margin-bottom: 2rem;">@ErrorMessage</p>
            <div style="display:flex; gap: 1rem;">
                <button class="btn-cancel" @onclick="() => ShowError = false" style="padding: 0.8rem 2rem; border: 1px solid var(--border);">Volver</button>
                <button class="btn-primary" @onclick="GenerateRoadmap" style="padding: 0.8rem 2rem; background: black; color: white;">Reintentar</button>
            </div>
        </div>
    }
    else if (IsLoading)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;">
            <svg class="spinner" viewBox="0 0 50 50" style="width: 50px; height: 50px; animation: spin 1s linear infinite;">
                <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="90 150" stroke-linecap="round"></circle>
            </svg>
            <style>
                @@keyframes spin { 100% { transform: rotate(360deg); } }
            </style>
            <h3 style="margin-top: 1.5rem;">Generando tu hoja de ruta...</h3>
            <p style="color: var(--muted); font-size: 0.95rem; margin-top: 0.5rem; max-width: 400px; text-align: center;">La IA est� analizando tus resultados y comentarios de los jurados. Esto puede tardar unos segundos.</p>
            <div style="width: 100%; max-width: 300px; height: 6px; background: var(--border); border-radius: 4px; margin-top: 1.5rem; overflow: hidden;">
                <div style="width: 50%; height: 100%; background: var(--text); border-radius: 4px; animation: load-bar 2s ease-in-out infinite;"></div>
            </div>
            <style>
                @@keyframes load-bar { 0% { transform: translateX(-100%); } 100% { transform: translateX(200%); } }
            </style>
        </div>
    }
    else if (!string.IsNullOrEmpty(MarkdownText))
    {
        <style>
            .markdown-rendered-content h1, .markdown-rendered-content h2, .markdown-rendered-content h3 { margin-top: 2rem; margin-bottom: 1rem; }
            .markdown-rendered-content ul { padding-left: 1.5rem; margin-bottom: 1.5rem; }
            .markdown-rendered-content li { margin-bottom: 0.5rem; }
            .markdown-rendered-content p { margin-bottom: 1rem; }

            @@media print {
                body * {
                    visibility: hidden;
                }
                #printable-roadmap, #printable-roadmap * {
                    visibility: visible;
                }
                #printable-roadmap {
                    position: absolute;
                    left: 0;
                    top: 0;
                    width: 100%;
                    padding: 0;
                    margin: 0;
                    border: none;
                }
                /* Hide buttons inside the printable area */
                #printable-roadmap .btn-cancel,
                #printable-roadmap .btn-primary,
                #printable-roadmap .no-print {
                    display: none !important;
                }
                .print-only {
                    display: block !important;
                }
            }
        </style>

        <div id="printable-roadmap">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <div style="width: 24px, height: 24px; border-radius: 50%; background: rgba(34, 201, 132, 0.15); display: flex; align-items: center; justify-content: center; color: var(--success);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="width: 14px; height: 14px;"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                        <h3 style="margin: 0; font-size: 1.1rem;">Hoja de Ruta Generada</h3>
                        <div style="font-size: 0.75rem; color: var(--muted);">Generado el @DateTime.Now.ToString("dd/MM/yyyy 'a las' HH:mm")</div>
                    </div>
                </div>
                <button class="btn-cancel no-print" style="background: transparent; border: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem;" @onclick="GenerateRoadmap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
                    Regenerar
                </button>
            </div>

            <div class="markdown-rendered-content" style="line-height: 1.6; color: var(--text);">
                @((MarkupString)HtmlText)
            </div>

            <div class="no-print" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <p style="color: var(--muted); font-size: 0.85rem; margin: 0;">Esta hoja de ruta se ha generado autom�ticamente. �sala como gu�a orientativa.</p>
                <button class="btn-primary" style="background: transparent; color: var(--text); border: 2px solid var(--text); font-weight: 600; padding: 0.6rem 1.5rem;" @onclick="DescargarPDF">Descargar PDF</button>
            </div>
            
            <!-- Visible only when printing -->
            <div style="display: none;" class="print-only">
                <div style="margin-top: 3rem; border-top: 1px solid #ddd; padding-top: 1rem; color: #555; font-size: 0.85rem;">
                    Esta hoja de ruta se ha generado autom�ticamente. �sala como gu�a orientativa.
                </div>
            </div>
            <style>
                @@media print {
                    .print-only {
                        display: block !important;
                    }
                }
            </style>
        </div>
    }
    else
    {
        <div style="color: var(--muted); margin-bottom: 1.5rem;">
            <svg viewBox="0 0 24 24" width="64" height="64" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                <path d="M12 3L14.5 8.5L21 11L14.5 13.5L12 19L9.5 13.5L3 11L9.5 8.5L12 3Z"/>
                <path d="M19 4L19.5 5.5L21 6L19.5 6.5L19 8L18.5 6.5L17 6L18.5 5.5L19 4Z"/>
            </svg>
        </div>
        <h2 style="margin-bottom: 1rem;">Genera tu Hoja de Ruta</h2>
        <p style="color: var(--muted); max-width: 550px; margin-bottom: 2rem; line-height: 1.5;">La Inteligencia Artificial analizar� las puntuaciones y comentarios que has recibido de los jurados en todos tus proyectos evaluados para crear un plan de mejora personalizado con recomendaciones espec�ficas y pasos a seguir.</p>
        
        <div style="background: rgba(250, 204, 21, 0.1); border: 1px solid rgba(250, 204, 21, 0.3); padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 2.5rem; color: var(--text); max-width: 600px; text-align: center;">
            <p style="margin: 0; font-size: 0.85rem;"><strong><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px; display:inline-block; vertical-align:middle; margin-right: 4px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg> INFORMACI�N</strong><br/>Para poder generar tu hoja de ruta, debes tener al menos un proyecto evaluado con resultados y comentarios de los jurados. La generaci�n puede tardar entre 10-30 segundos.</p>
        </div>

        <button class="btn-primary" style="background: black; color: white; border: none; padding: 0.8rem 2rem; font-size: 1rem; display: flex; align-items: center; gap: 0.5rem;" @onclick="GenerateRoadmap">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"><path d="M12 3v3"/><path d="M18.5 5.5l-2 2"/><path d="M21 12h-3"/><path d="M18.5 18.5l-2-2"/><path d="M12 21v-3"/><path d="M5.5 18.5l2-2"/><path d="M3 12h3"/><path d="M5.5 5.5l2 2"/></svg>
            Generar Hoja de Ruta
        </button>
    }
</div>

@code {
    private bool IsLoading = false;
    private bool ShowError = false;
    private string ErrorMessage = "";
    private string MarkdownText = "";
    private string HtmlText = "";
    private bool HasGeneratedResult => !string.IsNullOrEmpty(MarkdownText);
    private int CurrentUserId = 0;

    protected override async Task OnInitializedAsync()
    {
        var userJson = await AuthService.GetUsuarioActivoAsync();
        if (string.IsNullOrEmpty(userJson))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        using var doc = System.Text.Json.JsonDocument.Parse(userJson);
        if (doc.RootElement.TryGetProperty("id", out var idProp) || doc.RootElement.TryGetProperty("Id", out idProp))
        {
            CurrentUserId = idProp.GetInt32();
        }
    }

    private async Task DescargarPDF()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    private async Task GenerateRoadmap()
    {
        if (CurrentUserId <= 0) return;

        IsLoading = true;
        ShowError = false;
        ErrorMessage = "";
        StateHasChanged();

        try
        {
            // Se asume que el token o la cabecera necesaria la env�a el Http o se saca de AuthService si fuera necesario.
            // Para mantener compatibilidad con lo implementado, enviamos el custom header X-User-Id
            var requestMessage = new HttpRequestMessage(HttpMethod.Post, "api/Concursante/hoja-ruta/generar");
            requestMessage.Headers.Add("X-User-Id", CurrentUserId.ToString());

            var res = await Http.SendAsync(requestMessage);
            if (res.IsSuccessStatusCode)
            {
                var dto = await res.Content.ReadFromJsonAsync<HojaRutaResponseDto>();
                if (dto != null && !string.IsNullOrEmpty(dto.Markdown))
                {
                    MarkdownText = dto.Markdown;
                    var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
                    HtmlText = Markdown.ToHtml(MarkdownText, pipeline);
                }
                else
                {
                    ShowError = true;
                    ErrorMessage = "La respuesta del servidor no tiene el formato esperado.";
                }
            }
            else
            {
                ShowError = true;
                // Intentar leer el JSON de error
                try 
                {
                    var errDict = await res.Content.ReadFromJsonAsync<System.Collections.Generic.Dictionary<string, string>>();
                    if (errDict != null)
                    {
                        if (errDict.ContainsKey("message"))
                        {
                            ErrorMessage = errDict["message"];
                        }
                        else if (errDict.ContainsKey("error"))
                        {
                            ErrorMessage = errDict["error"];
                        }
                        else
                        {
                            ErrorMessage = "No ha sido posible generar la hoja de ruta en este momento.";
                        }
                    }
                    else
                    {
                        ErrorMessage = "No ha sido posible generar la hoja de ruta en este momento.";
                    }
                } 
                catch 
                {
                    ErrorMessage = "Ocurri� un error en la comunicaci�n con el servidor.";
                }
            }
        }
        catch (Exception ex)
        {
            ShowError = true;
            ErrorMessage = $"Error de conexi�n con la IA: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
