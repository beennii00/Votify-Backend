@page "/gestion-estado"
@using Shared.DTO
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject Web.Services.SimpleAuthService AuthService

<div class="breadcrumb" style="display:flex; align-items:center; gap:.5rem; font-size:.8rem; color:var(--muted); margin-bottom:2rem;">
    <a href="/listado-eventos" style="color:var(--muted); text-decoration:none;">Votaciones</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:12px; height:12px; opacity:.5;"><polyline points="9 18 15 12 9 6"/></svg>
    <a href="/detalle-votacion?eventoId=@EventoId&votacionId=@VotacionId" style="color:var(--muted); text-decoration:none; cursor: pointer;">@(votacion?.Nombre ?? $"VOT {VotacionId}")</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:12px; height:12px; opacity:.5;"><polyline points="9 18 15 12 9 6"/></svg>
    <span style="color:var(--text);">Gestión Estado</span>
</div>

<div style="margin-bottom: 2rem;">
    <Web.Components.PageHeader Title="Gestión Manual Estado de Votación" />
</div>

@if (Cargando)
{
    <p>Cargando información...</p>
}
else if (votacion == null)
{
    <p>Error al cargar la votación.</p>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" style="margin-bottom: 1rem;">@errorMessage</div>
    }

    <div class="form-card" style="margin-bottom: 2rem; padding: 2rem; background: var(--bg-hover);">
        <p style="font-size: 0.85rem; font-weight: bold; margin-bottom: 0.5rem; letter-spacing: 1px; color: var(--muted);">ESTADO ACTUAL</p>
        <h2 style="font-size: 1.5rem; margin-bottom: 2rem; font-family: monospace;">@(IsFinished ? "Cerrada" : IsPendiente ? "Pendiente de iniciar" : IsPausada ? "Pausada" : "Activa")</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div>
                <p style="font-size: 0.85rem; font-weight: bold; margin-bottom: 0.5rem; letter-spacing: 1px; color: var(--muted);">FECHA INICIO</p>
                <p style="font-family: monospace;">@votacion.FechaInicio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            <div>
                <p style="font-size: 0.85rem; font-weight: bold; margin-bottom: 0.5rem; letter-spacing: 1px; color: var(--muted);">FECHA FIN</p>
                <p style="font-family: monospace;">@votacion.FechaFin.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>

    <div style="margin-bottom: 2rem;">
        <p style="font-size: 0.85rem; font-weight: bold; margin-bottom: 1rem; letter-spacing: 1px; color: var(--muted);">ACCIONES DISPONIBLES</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <button class="@GetButton1Class()" disabled="@(!CanButton1)" @onclick="OnButton1Click">@GetButton1Label()</button>
            <button class="@GetButton2Class()" disabled="@(!CanButton2)" @onclick="OnButton2Click">@GetButton2Label()</button>
        </div>
    </div>

    <div style="background: rgba(250, 204, 21, 0.1); border: 1px solid rgba(250, 204, 21, 0.3); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; color: var(--text);">
        <h4 style="margin-top: 0; font-size: 0.9rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            ℹ️ INFORMACIÓN
        </h4>
        <ul style="margin: 0; padding-left: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-family: monospace; font-size: 0.9rem;">
            <li><strong>Iniciar / Finalizar:</strong> Si está pendiente, activa la votación y ajusta fecha/hora de inicio al momento actual. Si está iniciada, la cierra de forma definitiva y ajusta la fecha de fin al momento en que se pulsó.</li>
            <li><strong>Detener / Reanudar:</strong> Detener pausa la admisión de votos temporariamente. Reanudar vuelve a admitirlos tras la pausa. El reloj y las fechas continúan igual.</li>
        </ul>
    </div>

    <div style="display: flex; justify-content: flex-end;">
        <button class="btn-cancel" style="background: transparent; border: 1px solid var(--border); padding: 0.75rem 2rem; font-weight: bold;" @onclick='() => NavigationManager.NavigateTo($"/detalle-votacion?eventoId={EventoId}&votacionId={VotacionId}")'>Volver</button>
    </div>
}

@code {
    [SupplyParameterFromQuery] public int EventoId { get; set; }
    [SupplyParameterFromQuery] public int VotacionId { get; set; }

    private DetalleVotacionDto? votacion;
    private bool Cargando = true;
    private string errorMessage = "";

    private bool IsFinished => votacion != null && (DateTime.UtcNow >= votacion.FechaFin);
    private bool IsPendiente => votacion != null && (votacion.Estado == "Pendiente de iniciar" || DateTime.UtcNow < votacion.FechaInicio);
    private bool IsPausada => votacion?.Estado == "Pausada";
    private bool IsActiva => votacion != null && DateTime.UtcNow < votacion.FechaFin && DateTime.UtcNow > votacion.FechaInicio;

    private bool CanButton1 => votacion != null && !IsFinished;
    private bool CanButton2 => votacion != null && (IsActiva || IsPausada);

    private string GetButton1Label() => IsPendiente ? "Iniciar" : "Finalizar";
    private string GetButton2Label() => IsPausada ? "Reanudar" : "Detener";

    private string GetButton1Class() => !CanButton1 ? "btn-cancel" : (IsPendiente ? "btn-action-primary btn-state-success" : "btn-action-primary btn-state-close");
    private string GetButton2Class() => !CanButton2 ? "btn-cancel" : (IsPausada ? "btn-action-primary btn-state-success" : "btn-action-primary btn-state-extend");

    protected override async Task OnInitializedAsync()
    {
        if (EventoId <= 0 || VotacionId <= 0)
        {
            NavigationManager.NavigateTo("/listado-eventos");
            return;
        }

        await CargarData();
    }

    private async Task CargarData()
    {
        Cargando = true;
        errorMessage = "";
        try
        {
            votacion = await Http.GetFromJsonAsync<DetalleVotacionDto>($"api/Votacion/{EventoId}/{VotacionId}/detalle");
            if (votacion != null)
            {
                votacion.FechaInicio = votacion.FechaInicio.ToLocalTime();
                votacion.FechaFin = votacion.FechaFin.ToLocalTime();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al cargar el estado.";
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task OnButton1Click()
    {
        if (IsPendiente) await Accion("iniciar");
        else await Accion("finalizar");
    }

    private async Task OnButton2Click()
    {
        if (IsPausada) await Accion("reanudar");
        else if (IsActiva) await Accion("detener");
    }

    private async Task Accion(string tipo)
    {
        try
        {
            var res = await Http.PostAsync($"api/Votacion/{EventoId}/{VotacionId}/accion?accion={tipo}", null);
            if (res.IsSuccessStatusCode)
            {
                await CargarData();
            }
            else
            {
                var dict = await res.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                errorMessage = dict?["error"]?.ToString() ?? "Error al procesar la acción.";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}
