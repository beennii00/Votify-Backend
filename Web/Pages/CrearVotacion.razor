    private void AddCriterio()
    {
        VotacionModel.Criterios ??= new List<CriterioVotacionDto>();
        var next = VotacionModel.Criterios.Count + 1;
        VotacionModel.Criterios.Add(new CriterioVotacionDto { Nombre = $"Criterio {next}", Peso = 0.0M });
    }

    private void SelectEmoji(string emoji)
    {
        VotacionModel.Premio ??= new PremioFormDto { Emoji = EmojiOptions.First() };
        VotacionModel.Premio.Emoji = emoji;
    }

    private void OnAgregarPremioChanged()
    {
        if (VotacionModel.AgregarPremio)
        {
            VotacionModel.Premio ??= new PremioFormDto { Emoji = EmojiOptions.First() };

            if (string.IsNullOrWhiteSpace(VotacionModel.Premio.Emoji))
            {
                VotacionModel.Premio.Emoji = EmojiOptions.First();
            }
        }
        else
        {
            // Al desactivar, resetear estado de errores para próxima activación
