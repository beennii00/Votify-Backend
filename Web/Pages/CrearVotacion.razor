                            juradosSeleccionadosIds.Add(j.Id);
                        }
                    }
                    // Cargar campos de plantilla si existen
                    VotacionModel.TipoVotacion = response.TipoVotacion;
                    VotacionModel.ValorMaximoNumerico = response.ValorMaximoNumerico;
                    VotacionModel.Criterios = response.Criterios ?? new List<CriterioVotacionDto>();
                    if (VotacionModel.Criterios != null)
                    {
                        foreach (var c in VotacionModel.Criterios)
                        {
                            c.FechaInicio = c.FechaInicio.ToLocalTime();
                            c.FechaFin = c.FechaFin.ToLocalTime();
                        }
                    }
                    VotacionModel.EsPopular = response.EsPopular;

                    // cargar premio si existe
                    if (response.Premio != null)
                    {
                        VotacionModel.AgregarPremio = true;
                        VotacionModel.Premio = new PremioFormDto { Emoji = response.Premio.Emoji, Nombre = response.Premio.Nombre };
                    }
                }
            }

            else
            {
                VotacionModel.MaxVotesPerVoter = 3;
                VotacionModel.ValorMaximoNumerico = 5;
                if (Evento != null)
                {
                    VotacionModel.FechaInicio = Evento.FechaInicio;
                    VotacionModel.FechaFin = Evento.FechaFin;
                }
                else
                {
                    VotacionModel.FechaInicio = DateTime.Now;
                    VotacionModel.FechaFin = DateTime.Now.AddDays(7);
                }
            }

            // Inicializar EditContext y ValidationMessageStore para validación personalizada
            editContext = new EditContext(VotacionModel);
            validationMessageStore = new ValidationMessageStore(editContext);

            if (esAdmin)
            {
                await CargarTodosLosJurados();
            }
        }
        catch (Exception ex)
