    private async Task GuardarVotacion()
    {
        IsSaving = true;
        ErrorMessage = string.Empty;

        try
        {
            if (VotacionModel.FechaFin <= VotacionModel.FechaInicio)
            {
                ErrorMessage = "La fecha de fin debe ser posterior a la fecha de inicio.";
                IsSaving = false;
                return;
            }
            if (!EventoId.HasValue)
            {
                ErrorMessage = "No se pudo determinar el evento de la votación.";
                IsSaving = false;
                return;
            }
            if (Evento != null && (VotacionModel.FechaInicio < Evento.FechaInicio || VotacionModel.FechaFin > Evento.FechaFin))
            {
                ErrorMessage = "Las fechas de la votación deben estar dentro del rango de fechas del evento.";
                IsSaving = false;
                return;
            }

            // Asignar los IDs de los jurados seleccionados al modelo antes de guardar
            VotacionModel.JuradosAsignadosIds = juradosSeleccionadosIds.ToList();

            // Validación de premio en frontend
            if (VotacionModel.AgregarPremio)
            {
                VotacionModel.Premio ??= new PremioFormDto { Emoji = EmojiOptions.First() };
                if (string.IsNullOrWhiteSpace(VotacionModel.Premio.Emoji))
                {
                    VotacionModel.Premio.Emoji = EmojiOptions.First();
                }

                if (string.IsNullOrWhiteSpace(VotacionModel.Premio.Nombre))
                {
                    ErrorMessage = "Debes introducir un nombre para el premio antes de crear la votación.";
                    validationMessageStore?.Clear(new FieldIdentifier(VotacionModel.Premio, nameof(PremioFormDto.Nombre)));
                    validationMessageStore?.Add(new FieldIdentifier(VotacionModel.Premio, nameof(PremioFormDto.Nombre)), "El nombre del premio es obligatorio.");
                    editContext?.NotifyValidationStateChanged();
                    IsSaving = false;
                    StateHasChanged();
                    return;
                }
                else
                {
                    // borrar mensajes previos si existen
                    validationMessageStore?.Clear(new FieldIdentifier(VotacionModel.Premio, nameof(PremioFormDto.Nombre)));
                    // limpiar cartel superior si estaba seteado por esta validación
                    if (ErrorMessage == "El nombre del premio es obligatorio.")
                    {
                        ErrorMessage = string.Empty;
                        StateHasChanged();
                    }
                }
            }
            else
            {
                // Si no se agrega premio, limpiar errores relacionados
                if (VotacionModel.Premio != null)
                {
                    validationMessageStore?.Clear(new FieldIdentifier(VotacionModel.Premio, nameof(PremioFormDto.Nombre)));
                    editContext?.NotifyValidationStateChanged();
                }
            }

            HttpResponseMessage response;

            if (IsEdit)
            {
                // Validaciones adicionales según plantilla
                if (VotacionModel.TipoVotacion == TipoVotacion.Numerica && (!VotacionModel.ValorMaximoNumerico.HasValue || VotacionModel.ValorMaximoNumerico < 1))
                {
                    ErrorMessage = "Para votación numérica, indica el valor máximo de la escala.";
                    IsSaving = false;
                    return;
                }

                if (VotacionModel.TipoVotacion == TipoVotacion.CriteriosPorPeso)
                {
                    if (VotacionModel.Criterios == null || VotacionModel.Criterios.Count == 0)
                    {
                        ErrorMessage = "Agrega al menos un criterio para la votación por criterios.";
                        IsSaving = false;
                        return;
                    }

                    if (VotacionModel.Criterios.Any(c => c.Peso <= 0 || c.Peso > 1))
                    {
                        ErrorMessage = "El peso debe ser mayor a 0%.";
                        IsSaving = false;
                        return;
                    }

                    var sum = VotacionModel.Criterios.Sum(c => (double)c.Peso);
                    if (Math.Abs(sum - 1.0) > 0.01)
                    {
                        ErrorMessage = "La suma de los pesos de los criterios debe ser 1.0 (100%).";
                        IsSaving = false;
                        return;
                    }
                }

                VotacionModel.EventoId = EventoId.Value;
                
                var payload = System.Text.Json.JsonSerializer.Deserialize<VotacionFormDto>(System.Text.Json.JsonSerializer.Serialize(VotacionModel))!;
                payload.FechaInicio = payload.FechaInicio?.ToUniversalTime();
                payload.FechaFin = payload.FechaFin?.ToUniversalTime();
                if (payload.Criterios != null)
                {
                    foreach (var c in payload.Criterios)
                    {
                        c.FechaInicio = c.FechaInicio.ToUniversalTime();
                        c.FechaFin = c.FechaFin.ToUniversalTime();
                    }
                }
                
                response = await Http.PutAsJsonAsync($"api/Votacion/{EventoId}/{VotacionId}", payload);
            }
            else
            {
                // Validaciones adicionales antes de crear
                if (VotacionModel.TipoVotacion == TipoVotacion.Numerica && (!VotacionModel.ValorMaximoNumerico.HasValue || VotacionModel.ValorMaximoNumerico < 1))
                {
                    ErrorMessage = "Para votación numérica, indica el valor máximo de la escala.";
                    IsSaving = false;
                    return;
                }

                if (VotacionModel.TipoVotacion == TipoVotacion.CriteriosPorPeso)
                {
                    if (VotacionModel.Criterios == null || VotacionModel.Criterios.Count == 0)
                    {
                        ErrorMessage = "Agrega al menos un criterio para la votación por criterios.";
                        IsSaving = false;
                        return;
                    }

                    if (VotacionModel.Criterios.Any(c => c.Peso <= 0 || c.Peso > 1))
                    {
                        ErrorMessage = "El peso debe ser mayor a 0.";
                        IsSaving = false;
                        return;
                    }

                    var sum2 = VotacionModel.Criterios.Sum(c => (double)c.Peso);
                    if (Math.Abs(sum2 - 1.0) > 0.01)
                    {
                        ErrorMessage = "La suma de los pesos de los criterios debe ser 1.0 (100%).";
                        IsSaving = false;
                        return;
                    }
                }

                VotacionModel.EventoId = EventoId.Value;
                
                var payload = System.Text.Json.JsonSerializer.Deserialize<VotacionFormDto>(System.Text.Json.JsonSerializer.Serialize(VotacionModel))!;
                payload.FechaInicio = payload.FechaInicio?.ToUniversalTime();
                payload.FechaFin = payload.FechaFin?.ToUniversalTime();
                if (payload.Criterios != null)
                {
                    foreach (var c in payload.Criterios)
                    {
                        c.FechaInicio = c.FechaInicio.ToUniversalTime();
                        c.FechaFin = c.FechaFin.ToUniversalTime();
                    }
                }
                
                response = await Http.PostAsJsonAsync($"api/Votacion", payload);
            }

            if (response.IsSuccessStatusCode)
            {
                ShowToast = true;
                StateHasChanged();
                await Task.Delay(2000);
                if (FromDetail && IsEdit)
                {
                    Navigation.NavigateTo($"/detalle-votacion?eventoId={EventoId}&votacionId={VotacionId}");
                }
                else
                {
                    Navigation.NavigateTo($"/detalle-evento?Id={EventoId}");
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                try
                {
                    using var doc = JsonDocument.Parse(content);
                    var root = doc.RootElement;
                    JsonElement errorsElement;
                    var errors = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);

                    if (root.ValueKind == JsonValueKind.Object && root.TryGetProperty("errors", out errorsElement) && errorsElement.ValueKind == JsonValueKind.Object)
                    {
                        foreach (var prop in errorsElement.EnumerateObject())
                        {
                            var msgs = new List<string>();
                            if (prop.Value.ValueKind == JsonValueKind.Array)
                            {
                                foreach (var item in prop.Value.EnumerateArray())
                                    msgs.Add(item.GetString() ?? string.Empty);
                            }
                            else if (prop.Value.ValueKind == JsonValueKind.String)
                            {
                                msgs.Add(prop.Value.GetString() ?? string.Empty);
                            }
                            errors[prop.Name] = msgs;
                        }
                    }
                    else if (root.ValueKind == JsonValueKind.Object)
                    {
                        // Fallback: root contiene field->messages
                        foreach (var prop in root.EnumerateObject())
                        {
                            if (prop.Value.ValueKind == JsonValueKind.Array)
                            {
                                var msgs = new List<string>();
                                foreach (var item in prop.Value.EnumerateArray()) msgs.Add(item.GetString() ?? string.Empty);
                                errors[prop.Name] = msgs;
                            }
                        }
                    }

                    if (errors.Count > 0)
                    {
                        // Clear previous server validations
                        validationMessageStore?.Clear();

                        foreach (var kv in errors)
                        {
                            var key = kv.Key;
                            var msgs = kv.Value;

                            FieldIdentifier fieldId;
                            if (key.Contains('.'))
                            {
                                var parts = key.Split('.', 2);
                                var first = parts[0];
                                var second = parts.Length > 1 ? parts[1] : string.Empty;

                                if (string.Equals(first, "Premio", StringComparison.OrdinalIgnoreCase) && VotacionModel.Premio != null)
                                    fieldId = new FieldIdentifier(VotacionModel.Premio, second);
                                else
                                    fieldId = new FieldIdentifier(VotacionModel, first);
                            }
                            else
                            {
                                if (string.Equals(key, "Nombre", StringComparison.OrdinalIgnoreCase))
                                    fieldId = new FieldIdentifier(VotacionModel, "Nombre");
                                else
                                    fieldId = new FieldIdentifier(VotacionModel, key);
                            }

                            validationMessageStore?.Add(fieldId, msgs);
                        }

                        editContext?.NotifyValidationStateChanged();
                        IsSaving = false;
                        return;
                    }

                    // si no hay estructura reconocible, mostrar raw
                    ErrorMessage = $"Error al guardar: {content}";
                }
                catch
                {
                    ErrorMessage = $"Error al guardar: {content}";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Excepción al guardar: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

